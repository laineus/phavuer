{
  "name": "phavuer",
  "version": "0.21.0",
  "description": "A wrapper library that integrates Phaser 4 with Vue 3.",
  "author": "Laineus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laineus/phavuer.git"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/phavuer.esm.min.js",
      "require": "./dist/phavuer.min.js"
    }
  },
  "main": "dist/phavuer.min.js",
  "module": "dist/phavuer.esm.min.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest"
  },
  "dependencies": {
    "phaser": "^4.1.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser-webdriverio": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "9.33.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "webdriverio": "^9.27.1"
  }
}
